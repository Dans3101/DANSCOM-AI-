{
  "entities": {
    "Analytics": {
      "title": "Analytics",
      "description": "Command usage statistics",
      "type": "object",
      "properties": {
        "usageCount": { "type": "number" },
        "lastUsed": { "type": "string", "format": "date-time" }
      },
      "required": ["usageCount", "lastUsed"]
    },
    "User": {
      "title": "User",
      "description": "Bot user profile",
      "type": "object",
      "properties": {
        "usageCount": { "type": "number" },
        "lastSeen": { "type": "string", "format": "date-time" }
      }
    },
    "Setting": {
      "title": "Setting",
      "description": "Bot feature configuration",
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["enabled", "updatedAt"]
    },
    "SessionData": {
      "title": "SessionData",
      "description": "Serialized WhatsApp authentication state",
      "type": "object",
      "properties": {
        "data": { "type": "string" }
      },
      "required": ["data"]
    },
    "Contact": {
      "title": "Contact",
      "description": "Saved WhatsApp contact",
      "type": "object",
      "properties": {
        "jid": { "type": "string" },
        "name": { "type": "string" },
        "savedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["jid", "name", "savedAt"]
    },
    "PremiumSubscription": {
      "title": "PremiumSubscription",
      "description": "User subscription details",
      "type": "object",
      "properties": {
        "expiry": { "type": "string", "format": "date-time" },
        "plan": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["expiry"]
    }
  },
  "firestore": {
    "analytics/{commandId}": {
      "schema": "Analytics",
      "description": "Usage stats for specific commands"
    },
    "users/{userId}": {
      "schema": "User",
      "description": "Bot user records"
    },
    "settings/{featureId}": {
      "schema": "Setting",
      "description": "Global feature flags"
    },
    "sessions/{recordId}": {
      "schema": "SessionData",
      "description": "Auth state fragments"
    },
    "contacts/{jid}": {
      "schema": "Contact",
      "description": "Saved contacts directory"
    },
    "premium/{userId}": {
      "schema": "PremiumSubscription",
      "description": "Premium access records"
    }
  }
}
