# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# FIREBASE CONFIG
FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
FIREBASE_PRIVATE_KEY="YOUR_PRIVATE_KEY"
FIREBASE_CLIENT_EMAIL="YOUR_CLIENT_EMAIL"

# BOT CONFIG
OWNER_NUMBER="254..."
PREFIX="."
PORT=3000

# OPENAI (Optional, using Gemini as default)
OPENAI_API_KEY=""

# INTASEND PAYMENT INTEGRATION (Automated billing and payouts gateway)
# Public and private secret keys are auto-detected. Set INTASEND_IS_SANDBOX to false to force real live money transactions.
INTASEND_PUBLIC_KEY="YOUR_INTASEND_PUBLIC_KEY"
INTASEND_SECRET_KEY="YOUR_INTASEND_SECRET_KEY"
INTASEND_IS_SANDBOX="false"
